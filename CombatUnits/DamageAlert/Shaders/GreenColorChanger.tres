[gd_resource type="ShaderMaterial" format=3 uid="uid://bgd8hrasn8fk2"]

[sub_resource type="Shader" id="Shader_6c2of"]
code = "shader_type spatial;
// 如果你希望飄字不受場景燈光影響（保持原本像素顏色），請開啟 unshaded
render_mode unshaded;

uniform sampler2D albedo_texture : source_color;
uniform vec4 ori_color: source_color = vec4(1.0, 1.0, 1.0, 1.0);
uniform vec4 new_color: source_color;
uniform float threshold: hint_range(0.0, 1.75, 0.001) = 0.1;

vec3 rgb2hsv(vec3 c) {
    vec4 K = vec4(0.0, -1.0 / 3.0, 2.0 / 3.0, -1.0);
    vec4 p = mix(vec4(c.bg, K.wz), vec4(c.gb, K.xy), step(c.b, c.g));
    vec4 q = mix(vec4(p.xyw, c.r), vec4(c.r, p.yzx), step(p.x, c.r));

    float d = q.x - min(q.w, q.y);
    float e = 1.0e-10;
    return vec3(abs(q.z + (q.w - q.y) / (6.0 * d + e)), d / (q.x + e), q.x);
}

vec3 hsv2rgb(vec3 c) {
    vec4 K = vec4(1.0, 2.0 / 3.0, 1.0 / 3.0, 3.0);
    vec3 p = abs(fract(c.xxx + K.xyz) * 6.0 - K.www);
    return c.z * mix(K.xxx, clamp(p - K.xxx, 0.0, 1.0), c.y);
}

void fragment() {
    // 3D 中使用 texture(albedo_texture, UV)
    vec4 current_color = texture(albedo_texture, UV);
    vec3 current_hsv = rgb2hsv(current_color.rgb);
    
    // 計算與原色的距離
    float diff = length(current_color.rgb - ori_color.rgb);
    
    if (diff < threshold) {
        vec3 new_hsv = rgb2hsv(new_color.rgb);
        // 保留原圖的飽和度(S)與明度(V)，僅替換色相(H)
        vec3 final_hsv = vec3(
            new_hsv.x,        // New Hue
            current_hsv.y,    // Original Saturation
            current_hsv.z     // Original Value
        );
        ALBEDO = hsv2rgb(final_hsv);
    } else {
        ALBEDO = current_color.rgb;
    }
    
    // 處理透明度，這在 3D 中非常重要
    ALPHA = current_color.a;
}"

[resource]
render_priority = 0
shader = SubResource("Shader_6c2of")
shader_parameter/ori_color = Color(1, 1, 1, 1)
shader_parameter/new_color = Color(0.2387, 0.77, 0.43350998, 1)
shader_parameter/threshold = 1.3650000648375
